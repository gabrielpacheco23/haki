(inline (distancia x1 y1 x2 y2)
  (sqrt (+ (* (- x2 x1) (- x2 x1)) 
           (* (- y2 y1) (- y2 y1)))))

(define (loop-dist iter x1 y1 x2 y2)
  (if (= iter 0)
      (displayln "Fim!")
      (begin
        (distancia x1 y1 x2 y2)        ;; Inlined (can use JIT)!
        (loop-dist (- iter 1) x1 y1 x2 y2))))

(time (loop-dist 5000000 10.5 20.2 55.0 100.8))
