;; Rendering and loop
(define (draw-snake body color)
  (if (null? body)
    0
    (let ((piece (car body)))
      (begin
        ; multiply by 20 to convert the grid coordinate to pixels
        (draw-rectangle (* piece:x 20) (* piece:y 20) 20 20 color)
        (draw-snake (cdr body) color)))))

(define (game-loop state)
  (if (window-should-close)
      (close-window)
      (let* ((state-with-input (process-input state))
             (new-state (update-game state-with-input)))
        (begin

          ; controle de velocidade
          (if (is-key-down KEY-SPACE)
              (set-target-fps 25)   ; velocidade turbo
              (set-target-fps 10))  ; velocidade normal
          
          (begin-drawing)
          (clear-background bg-color)
          (draw-snake new-state:obstacles obstacle-color)
          
          (let ((apple new-state:food))
            (draw-rectangle (* apple:x 20) (* apple:y 20) 20 20 apple-color))

          (if (eq? new-state:golden-apple #f)
              #f
              (draw-snake (list new-state:golden-apple) golden-color))
          
          (if new-state:dead
              (draw-snake new-state:snake dead-color)
              (draw-snake new-state:snake snake-color))

          ; draw score
          (let ((text-score (string-append "SCORE: " (number->string new-state:score))))
            (draw-text text-score 10 10 20 white))

          (if new-state:dead
            (begin
              (draw-text "GAME OVER!" 280 250 40 dead-color)
              (draw-text "Press ENTER to restart" 280 350 20 white))
              (display ""))
        
          (end-drawing)
          
          (game-loop new-state)))))


; Initial state: Snake in the middle (20, 15), going to the right (dx=1, dy=0)
(define (restart-game)
  (State (list (Pos 20 15) (Pos 19 15) (Pos 18 15))
          1 0
          (Pos (get-random-value 5 35) (get-random-value 5 25))
          #f
          0
          (gen-obstacles 5)
          #f
          0))

;; Game start
(set-trace-log-level LOG-WARNING)

(set-target-fps 10)
(displayln "Starting Snake Game in Haki...")


(init-window 800 600 "Haki: Snake Game")
(init-audio-device)
(define apple-crunch (load-sound "apple_crunch_sound.wav"))

(game-loop (restart-game))





