(require "../libraries/raylib.hk")

;; Colors
(define bg-color (Color 30 30 40 255))
(define snake-color (Color 0 228 48 255))   ; green
(define apple-color (Color 230 41 55 255))  ; red
(define dead-color (Color 100 100 100 255)) ; grey
(define obstacle-color (Color 100 130 100 255)) ; yellow
(define golden-color (Color 255 215 0 255))
(define white (Color 255 255 255 255))

;; Structs and states
(struct Pos (x y))
(struct State (snake dx dy food dead score obstacles golden-apple golden-timer))

;; Util
(define (remove-last lst)
  (if (null? (cdr lst))
    '()
    (cons (car lst) (remove-last (cdr lst)))))

(define (is-golden-apple? head golden)
  (if (eq? golden #f)
    #f
    (pos-equal? head golden)))

(define (gen-obstacles qtd)
  (if (= qtd 0)
    '()
    (cons (Pos (get-random-value 2 37) (get-random-value 2 27))
    (gen-obstacles (- qtd 1)))))

(define (pos-equal? p1 p2)
  (if (= p1:x p2:x)
    (if (= p1:y p2:y) #t #f) #f))

(define (hit-body? head body)
  (if (null? body)
    #f
    (if (pos-equal? head (car body))
      #t
      (hit-body? head (cdr body))))) 

; Verify colision with grid walls (40x30)
(define (out-of-screen? p)
  (if (< p:x 0) #t
  (if (> p:x 39) #t
  (if (< p:y 0) #t
  (if (> p:y 29) #t #f)))))

;; Update logic and input
(define (process-input state)
  (if state:dead
      state
      (let ((dx state:dx)
            (dy state:dy))
        (cond
          ;; 1. Se está na Vertical (dx = 0), aceita comandos Horizontais
          ((and (= dx 0) (is-key-down KEY-RIGHT)) 
           (begin (set! state:dx 1) (set! state:dy 0) state))
           
          ((and (= dx 0) (is-key-down KEY-LEFT))  
           (begin (set! state:dx -1) (set! state:dy 0) state))
          
          ;; 2. Se está na Horizontal (dy = 0), aceita comandos Verticais
          ((and (= dy 0) (is-key-down KEY-DOWN))  
           (begin (set! state:dx 0) (set! state:dy 1) state))
           
          ((and (= dy 0) (is-key-down KEY-UP))    
           (begin (set! state:dx 0) (set! state:dy -1) state))
          
          ;; 3. Fallback: Mantém o state intacto
          (else state)))))

(define (update-game state)
  (if state:dead
      (if (is-key-down KEY-ENTER) (restart-game) state)
      
      (let* ((head (car state:snake))
             (new-head (Pos (+ head:x state:dx) (+ head:y state:dy))))
        
        (begin
          ;; ==========================================
          ;; 1. LÓGICA DO TEMPO (TIMER DA MAÇÃ DOURADA)
          ;; ==========================================
          (if (> state:golden-timer 0)
              (begin
                (set! state:golden-timer (- state:golden-timer 1))
                ;; Se o tempo acabar, a maçã desaparece!
                (if (= state:golden-timer 0)
                    (set! state:golden-apple #f)
                    #f))
              #f)

          (cond
            ;; 2. Colisões Fatais (Paredes, Corpo, Pedras)
            ((out-of-screen? new-head)        (begin (set! state:dead #t) state))
            ((hit-body? new-head state:snake) (begin (set! state:dead #t) state))
            ((hit-body? new-head state:obstacles) (begin (set! state:dead #t) state))
            
            ;; 3. Comeu a MAÇÃ DOURADA? (50 Pontos!)
            ((is-golden-apple? new-head state:golden-apple)
             (begin
               (play-sound apple-crunch)
               (set! state:snake (cons new-head state:snake))
               (set! state:score (+ state:score 50))
               (set! state:golden-apple #f) ;; Some do mapa
               (set! state:golden-timer 0)
               state))

            ;; 4. Comeu a Maçã Normal? (10 Pontos + Chance de Dourada)
            ((pos-equal? new-head state:food) 
             (begin
               (play-sound apple-crunch)
               (set! state:snake (cons new-head state:snake))
               (set! state:food (Pos (get-random-value 0 39) (get-random-value 0 29)))
               (set! state:score (+ state:score 10))
               
               ;; ROLA OS DADOS: 10% de chance de spawnar a Dourada se não houver nenhuma!
               (if (and (eq? state:golden-apple #f) (= (get-random-value 1 10) 1))
                   (begin
                     (set! state:golden-apple (Pos (get-random-value 2 37) (get-random-value 2 27)))
                     (set! state:golden-timer 50)) ;; Dá 5 segundos (a 10 FPS) para o jogador!
                   #f)
               state))
            
            ;; 5. Movimento normal
            (else
             (begin
               (set! state:snake (cons new-head (remove-last state:snake)))
               state)))))))

